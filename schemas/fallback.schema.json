{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fallback Providers Configuration",
  "type": "object",
  "required": ["providers", "maxRetries", "timeoutMs"],
  "properties": {
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "priority", "apiKeyEnv", "healthEndpoint"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "number",
            "minimum": 1
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "apiKeyEnv": {
            "type": "string",
            "minLength": 1
          },
          "healthEndpoint": {
            "type": "string",
            "minLength": 1,
            "pattern": "^https?://"
          }
        },
        "additionalProperties": false
      }
    },
    "maxRetries": {
      "type": "number",
      "minimum": 0
    },
    "timeoutMs": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "healthCheckIntervalMs": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
