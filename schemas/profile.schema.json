{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Profile Configuration",
  "type": "object",
  "required": ["id", "name", "description", "provider", "model", "maxTokens", "temperature", "apiKeyEnv", "tokenSaving"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "enum": ["openai", "anthropic", "ollama", "auto"]
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "maxTokens": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2
    },
    "apiKeyEnv": {
      "type": "string",
      "minLength": 1
    },
    "tokenSaving": {
      "type": "object",
      "required": ["contextTruncation", "maxContextMessages"],
      "properties": {
        "contextTruncation": {
          "type": "boolean"
        },
        "maxContextMessages": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "aggressiveSummarization": {
          "type": "boolean"
        },
        "skipSystemPromptRepetition": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
